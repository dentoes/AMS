programa {
  funcao inicio() {
    real numero1,numero2, numero3, resultado
    
escreva("digite numero inteiro 1: ")
leia(numero1)
escreva("digite numero inteiro 2: ")
leia(numero2)
escreva("digite numero inteiro 3: ")
leia(numero3)
resultado=(numero1+numero2+numero3)

escreva("a lista de valores inteiros somados é: ", resultado)
  }
}
